# Copia este archivo a ".env" y rellena los valores.
# El archivo .env NUNCA debe subirse al repositorio (está en .gitignore).

SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role: secreta. La usan /sync/migrate, /auth/check-email, /auth/reset-password
# y /auth/account (eliminar cuenta).
SUPABASE_SERVICE_ROLE_KEY=
PORT=3000

# --- Restablecimiento de contraseña ---
# URL a la que Supabase redirige al hacer click en el correo de "olvidé mi contraseña"
# (debe estar en Authentication -> URL Configuration -> Redirect URLs de Supabase).
# Si no se define, /auth/forgot-password puede recibir 'redirectTo' en el body.
PASSWORD_RESET_REDIRECT_URL=http://localhost:5500/reset.html

# --- Autenticación con Google ---
# Google se configura POR COMPLETO en Supabase (Authentication -> Providers -> Google:
# pega ahí el Client ID y el Client Secret de Google Cloud Console).
# La API NO necesita ninguna variable de Google: valida los tokens contra Supabase.
# Por eso no hay GOOGLE_CLIENT_ID aquí.
#
# Hay dos flujos soportados, ambos sin variables en la API:
#   1) Web (consola de pruebas): el cliente hace signInWithOAuth con Supabase y manda el
#      accessToken resultante a POST /auth/google. Requiere añadir el origen de tu web a
#      Supabase -> Authentication -> URL Configuration -> Redirect URLs.
#   2) Android nativo (Credential Manager / One Tap): la app obtiene un idToken de Google
#      y lo manda a POST /auth/google/idtoken (la API hace signInWithIdToken). Requiere:
#        - tener creados en Google Cloud un OAuth Client ID *Web* y uno *Android*
#          (este último con el package name + huella SHA-1 de la app);
#        - en la app, pasar el Client ID *Web* como serverClientId de Credential Manager;
#        - añadir ese/esos Client ID en Supabase -> Authentication -> Providers -> Google
#          -> "Authorized Client IDs".

# --- Generación de "content" con IA (Gemini) ---
# API key de Google AI Studio (https://aistudio.google.com/apikey). SECRETA.
GEMINI_API_KEY=
# Modelo a usar. Opciones probadas: gemini-2.5-flash-lite (barato) o gemini-2.5-flash (mejor calidad).
# Nota: gemini-2.0-flash puede dar 429 (limit:0) según la cuota de tu cuenta.
GEMINI_MODEL=gemini-2.5-flash-lite
# Gating de costos: cuándo regenerar el contenido desde la última generación.
CONTENT_MIN_NEW_VISITS=10
CONTENT_MIN_PRODUCT_CHANGES=3
CONTENT_REGEN_DAYS=30
