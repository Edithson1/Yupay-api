# Copia este archivo a ".env" y rellena los valores.
# El archivo .env NUNCA debe subirse al repositorio (está en .gitignore).

SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role: secreta. La usan /sync/migrate, /auth/check-email, /auth/reset-password
# y /auth/account (eliminar cuenta).
SUPABASE_SERVICE_ROLE_KEY=
PORT=3000

# --- Restablecimiento de contraseña (por CÓDIGO de 6 dígitos, no por enlace) ---
# El flujo ya NO usa una URL de redirección. POST /auth/forgot-password envía un código de
# 6 dígitos (OTP) y POST /auth/verify-reset-code lo valida. Para que el correo traiga el
# código en vez de un enlace, edita la plantilla de Supabase:
#   Authentication -> Email Templates -> "Reset Password" -> usa {{ .Token }} (el OTP).
# La longitud del código (6 por defecto) se ajusta en Authentication -> "Email OTP Length".
# IMPORTANTE: para que el correo se ENTREGUE a usuarios reales, Supabase necesita SMTP propio
# (Authentication -> SMTP Settings). El email integrado es SOLO para desarrollo (muy limitado).
# No hay variable de entorno que configurar para esto en la API (todo es config de Supabase).

# --- Autenticación con Google ---
# Google se configura en Supabase (Authentication -> Providers -> Google: pega ahí el
# Client ID y el Client Secret *Web* de Google Cloud Console). La API valida los tokens
# contra Supabase, así que estas variables son OPCIONALES: solo se usan para (a) exponer
# los Client ID a los clientes vía GET /auth/config y (b) pre-validar el `aud` del idToken
# en POST /auth/google/idtoken con un mensaje de error claro. Déjalas vacías y todo sigue
# funcionando (la validación real la hace Supabase).
#
# Client ID *Web* (Google Cloud -> Credentials -> OAuth client ID, tipo "Web application").
# La app Android lo usa como serverClientId de Credential Manager.
GOOGLE_WEB_CLIENT_ID=
# Client ID *Android* (Google Cloud -> OAuth client ID, tipo "Android": package + SHA-1).
GOOGLE_ANDROID_CLIENT_ID=
#
# Flujos soportados:
#   1) Web (consola de pruebas): signInWithOAuth con Supabase -> accessToken -> POST /auth/google.
#      Requiere el origen de tu web en Supabase -> Authentication -> URL Configuration -> Redirect URLs.
#   2) Android nativo (Credential Manager / One Tap): idToken de Google -> POST /auth/google/idtoken
#      (la API hace signInWithIdToken). Requiere:
#        - en Google Cloud, un OAuth Client ID *Web* y uno *Android* (package + SHA-1);
#        - en la app, pasar el Client ID *Web* como serverClientId;
#        - en Supabase -> Authentication -> Providers -> Google -> "Authorized Client IDs",
#          añadir el Client ID Web y el de Android (ese campo admite VARIOS separados por coma;
#          el campo principal "Client ID" guarda solo uno —el Web—, pero los demás caben aquí).

# --- Generación de "content" con IA (Gemini) ---
# API key de Google AI Studio (https://aistudio.google.com/apikey). SECRETA.
GEMINI_API_KEY=
# Modelo a usar. Opciones probadas: gemini-2.5-flash-lite (barato) o gemini-2.5-flash (mejor calidad).
# Nota: gemini-2.0-flash puede dar 429 (limit:0) según la cuota de tu cuenta.
GEMINI_MODEL=gemini-2.5-flash-lite
# Gating de costos: cuándo regenerar el contenido desde la última generación.
CONTENT_MIN_NEW_VISITS=10
CONTENT_MIN_PRODUCT_CHANGES=3
CONTENT_REGEN_DAYS=30
